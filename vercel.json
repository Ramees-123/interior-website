{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/interior-website/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(ngsw-worker\\.js|ngsw\\.json)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
